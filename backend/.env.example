PORT=3000
MONGODB_URI=mongodb://localhost:27017/cosmetics
TELEGRAM_BOT_TOKEN=your_bot_token_here
MINIAPP_URL=https://your-miniapp-url.com
ADMIN_TELEGRAM_ID=your_telegram_user_id
ADMIN_TELEGRAM_NICK=@your_telegram_username

# Webhook (production): Railway sets RAILWAY_PUBLIC_DOMAIN automatically.
# For Render/Fly.io, set WEBHOOK_DOMAIN=https://your-app.onrender.com (no trailing slash)
# RAILWAY_PUBLIC_DOMAIN=
# WEBHOOK_DOMAIN=

# LibreTranslate API (optional - defaults to https://libretranslate.com)
# LIBRETRANSLATE_URL=https://libretranslate.com
# LIBRETRANSLATE_API_KEY=optional_api_key_for_rate_limits
